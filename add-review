UPDATE `products` p
LEFT JOIN (
    SELECT product_id, ROUND(AVG(rating), 1) AS avg_rating, COUNT(*) AS review_count
    FROM `reviews`
    GROUP BY product_id
) r ON r.product_id = p.id
SET p.avg_rating = COALESCE(r.avg_rating, 0),
    p.review_count = COALESCE(r.review_count, 0);



COMMIT;
SET FOREIGN_KEY_CHECKS = 1;

-- Validation queries.
SELECT COUNT(*) AS total_reviews FROM `reviews`;
SELECT COUNT(DISTINCT product_id) AS reviewed_product_count FROM `reviews`;
SELECT MIN(created_at) AS earliest_review_time, MAX(created_at) AS latest_review_time FROM `reviews`;
SELECT product_id, COUNT(*) AS reviews_per_product FROM `reviews` GROUP BY product_id HAVING COUNT(*) <> 7;
SELECT r.user_id FROM `reviews` r LEFT JOIN `users` u ON u.id = r.user_id WHERE u.id IS NULL GROUP BY r.user_id;
SELECT COUNT(*) AS future_reviews FROM `reviews` WHERE created_at > '2026-06-04 18:20:00';
